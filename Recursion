// Problem: Reverse Stack
// Platform: GFG
// Approach: Recursion + insertAtBottom


class Solution {
    
  public:
       
    void insertAtbottom(stack<int>&st,int element)
    {
        if(st.empty())
        {
            st.push(element);
            return;
        }
        
        int top = st.top();
        st.pop();
        
        insertAtbottom(st,element);
        st.push(top);
        
    }
    
    void reverseStack(stack<int> &st) {
        // code here
        
        if(st.empty()) return;
        
        int top = st.top();
        st.pop();
        
        reverseStack(st);
        
        insertAtbottom(st,top);
        
    }
};
